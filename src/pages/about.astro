---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="About | Aoi Tsukikage Engineering"
	description="About route placeholder for the first portfolio information architecture pass."
	currentPath={Astro.url.pathname}
>
	<section class="placeholder">
		<p class="eyebrow">About</p>
		<h1>About content will be structured in a later pass.</h1>
		<p>
			This page currently reserves the shared layout and navigation entry point
			without introducing the second-batch narrative sections or final copy.
		</p>
	</section>
</SiteLayout>

<style>
	.placeholder {
		display: grid;
		gap: 1rem;
		max-width: 44rem;
	}

	.eyebrow {
		color: var(--accent);
		letter-spacing: 0.08em;
		margin: 0;
		text-transform: uppercase;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 7vw, 4.25rem);
		line-height: 1.05;
		margin: 0;
	}

	p {
		line-height: 1.7;
		margin: 0;
		max-width: 38rem;
	}
</style>
