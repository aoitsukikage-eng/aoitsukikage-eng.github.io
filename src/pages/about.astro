---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="About | Aoi Tsukikage Engineering"
	description="About page scaffold with placeholder sections for introduction, background, and opportunity fit."
	currentPath={Astro.url.pathname}
>
	<div class="page-stack">
		<section class="section-card section-shell" data-reveal id="about-hero" style="--reveal-order: 0;">
			<p class="section-kicker">[SYSTEM] about.hero</p>
			<p class="section-anchor">section/about/hero</p>
			<h1>About page placeholder defines the top-level self-introduction band.</h1>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>
				The structure is ready for future narrative content, but this pass keeps
				every line intentionally generic.
			</p>
			<div class="cta-row">
				<a class="cta-link" href="/contact">Contact</a>
				<a class="cta-link secondary" href="/projects">View Projects</a>
			</div>
		</section>

		<section class="section-card section-shell" data-reveal id="about-intro" style="--reveal-order: 1;">
			<p class="section-kicker">[SYSTEM] about.intro</p>
			<p class="section-anchor">section/about/intro</p>
			<h2>Self-introduction section holds the narrative summary placeholder.</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>
				Reserved for a concise introduction paragraph, current focus, and working
				context once real copy is approved.
			</p>
		</section>

		<section class="section-card section-shell" data-reveal id="about-education" style="--reveal-order: 2;">
			<p class="section-kicker">[SYSTEM] about.education</p>
			<p class="section-anchor">section/about/education</p>
			<h2>Education background section reserves a compact chronology slot.</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<ul class="bullet-list">
				<li>Placeholder line for education summary item one.</li>
				<li>Placeholder line for education summary item two.</li>
			</ul>
		</section>

		<section class="section-card section-shell" data-reveal id="about-opportunities" style="--reveal-order: 3;">
			<p class="section-kicker">[SYSTEM] about.opportunities</p>
			<p class="section-anchor">section/about/opportunities</p>
			<h2>Opportunity section marks what roles or collaborations will be described.</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>
				Reserved for future opportunity fit notes, collaboration scope, and a
				clear next-step CTA.
			</p>
			<div class="cta-row">
				<a class="cta-link" href="/contact">Start Contact Route</a>
			</div>
		</section>
	</div>
</SiteLayout>
