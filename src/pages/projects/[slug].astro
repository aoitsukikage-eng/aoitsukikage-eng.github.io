---
import { getCollection, render } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import {
	getStatusLabel,
	getTrackLabel,
	getVisibilityLabel,
	getVisibilityNote,
	isPlaceholderProject,
	sortProjects,
} from "../../lib/projects";

export async function getStaticPaths() {
	const projectEntries = sortProjects(await getCollection("projectCases"));

	return projectEntries.map((project) => ({
		params: { slug: project.data.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
const placeholder = isPlaceholderProject(project);
---

<SiteLayout
	title={`${project.data.title} | Projects | Aoi Tsukikage Engineering`}
	description={project.data.summary}
	currentPath={Astro.url.pathname}
>
	<div class="page-stack">
		<section class="section-card section-shell" data-reveal id="project-detail-hero" style="--reveal-order: 0;">
			<p class="section-kicker">[SYSTEM] projects.detail.hero</p>
			<p class="section-anchor">section/projects/detail/hero</p>
			<div class="meta-row">
				<span class="project-chip">{getTrackLabel(project.data.track)}</span>
				<span
					class:list={{
						"project-chip": true,
						"project-status": true,
						"is-active": project.data.status === "active",
						"is-ongoing": project.data.status === "ongoing",
					}}
				>
					{getStatusLabel(project.data.status)}
				</span>
				<span class="project-chip">
					{
						project.data.visibility === "confidential" && (
							<svg aria-hidden="true" class="lock-icon" viewBox="0 0 24 24">
								<path
									d="M7 10V7a5 5 0 0 1 10 0v3"
									fill="none"
									stroke="currentColor"
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="1.8"
								></path>
								<rect
									fill="none"
									height="10"
									rx="2"
									stroke="currentColor"
									stroke-width="1.8"
									width="14"
									x="5"
									y="10"
								></rect>
							</svg>
						)
					}
					{getVisibilityLabel(project.data.visibility)}
				</span>
				{
					placeholder && <span class="project-chip project-chip--placeholder">Placeholder</span>
				}
			</div>
			<h1>{project.data.title}</h1>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>{project.data.summary}</p>
			<div class="meta-row">
				{
					project.data.domain.map((domain) => (
						<span class="meta-chip">{domain.replaceAll("_", " ")}</span>
					))
				}
			</div>
		</section>

		<section class="section-card section-shell" data-reveal id="project-detail-safety" style="--reveal-order: 1;">
			<p class="section-kicker">[SYSTEM] projects.detail.safety-layer</p>
			<p class="section-anchor">section/projects/detail/safety-layer</p>
			<h2>Public-safe disclosure layer</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>{getVisibilityNote(project)}</p>
			<div class="detail-grid">
				<article class="detail-panel" data-reveal style="--reveal-order: 2;">
					<p class="section-tag">[MISSION] team-role</p>
					<h3>Team Role</h3>
					<p>{project.data.teamRole ?? "Role details are not published for this entry."}</p>
				</article>
				<article class="detail-panel" data-reveal style="--reveal-order: 3;">
					<p class="section-tag">[MISSION] background</p>
					<h3>Background</h3>
					<p>{project.data.background ?? "Background context is limited to this safe placeholder layer."}</p>
				</article>
				<article class="detail-panel" data-reveal style="--reveal-order: 4;">
					<p class="section-tag">[MISSION] disclosure</p>
					<h3>Disclosure Scope</h3>
					<p>{project.data.disclosure ?? "Only routing and taxonomy validation data is exposed."}</p>
				</article>
			</div>
		</section>

		<section class="section-card section-shell" data-reveal id="project-detail-body" style="--reveal-order: 2;">
			<p class="section-kicker">[SYSTEM] projects.detail.body</p>
			<p class="section-anchor">section/projects/detail/body</p>
			<h2>{placeholder ? "Placeholder Detail" : "Project Notes"}</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<div class="detail-body prose-shell">
				<Content />
			</div>
		</section>

		<section class="section-card section-shell" data-reveal id="project-detail-links" style="--reveal-order: 3;">
			<p class="section-kicker">[SYSTEM] projects.detail.links</p>
			<p class="section-anchor">section/projects/detail/links</p>
			<h2>Available public routes</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<div class="cta-row">
				<a class="cta-link" href="/projects">Back to Projects</a>
				{
					project.data.links?.repo && project.data.visibility === "public" && (
						<a
							class="cta-link secondary"
							href={project.data.links.repo}
							rel="noreferrer"
							target="_blank"
						>
							Repository
						</a>
					)
				}
				{
					project.data.links?.demo && project.data.visibility !== "confidential" && (
						<a
							class="cta-link secondary"
							href={project.data.links.demo}
							rel="noreferrer"
							target="_blank"
						>
							Demo
						</a>
					)
				}
				<a class="cta-link secondary" href="/contact">Request Context</a>
			</div>
		</section>
	</div>
</SiteLayout>

<style>
	.detail-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.detail-panel {
		display: grid;
		gap: 0.75rem;
	}

	.detail-body {
		color: rgba(244, 251, 255, 0.84);
	}

	.detail-body :global(p) {
		margin: 0;
	}

	.project-chip {
		backdrop-filter: blur(8px);
	}

	.project-status.is-active {
		background: var(--status-active-bg);
		border-color: var(--status-active-border);
		color: var(--status-active-text);
	}

	.project-status.is-ongoing {
		background: var(--status-ongoing-bg);
		border-color: var(--status-ongoing-border);
		color: var(--status-ongoing-text);
	}

	.project-chip--placeholder {
		border-style: dashed;
	}

	.lock-icon {
		height: 0.9rem;
		width: 0.9rem;
	}

	@media (max-width: 900px) {
		.detail-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
