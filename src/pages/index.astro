---
import SiteLayout from "../layouts/SiteLayout.astro";

const typingLines = [
	"[SYSTEM] PORTFOLIO SHELL LOADED",
	"[CLASS] PLACEHOLDER CONTENT LAYER",
	"[MISSION] SOLO UI VISUAL PASS ONLINE",
];

const quoteLines = [
	"Yesterday is history, tomorrow is a mystery,",
	"but today is a gift. That is why it is called the present.",
];

let quoteCharIndex = 0;
const quoteRows = quoteLines.map((line) =>
	Array.from(line).map((character) => ({
		character,
		index: quoteCharIndex++,
	})),
);
---

<SiteLayout
	title="Aoi Tsukikage Engineering"
	description="Solo Leveling inspired portfolio shell with native HUD interface, animated mission cards, and interactive quote treatment."
	currentPath={Astro.url.pathname}
>
	<div class="page-stack">
		<section class="hero-shell section-card" data-reveal id="home-hero" style="--reveal-order: 0;">
			<div class="hero-copy">
				<p class="section-kicker">[SYSTEM] home.hero</p>
				<p class="section-anchor">section/home/hero</p>
				<h1 class="hero-title">Portfolio interface redrawn as a system-grade HUD without replacing the placeholder content layer.</h1>
				<div class="hud-divider" aria-hidden="true"></div>
				<p class="summary">
					This pass upgrades the site shell, motion language, and quote treatment while
					keeping the current content scope intentionally placeholder-safe.
				</p>
				<div class="meta-row">
					<span class="meta-chip">Solo UI Pass</span>
					<span class="meta-chip">Native HTML/CSS</span>
					<span class="meta-chip">Placeholder Safe</span>
				</div>
				<div class="cta-row">
					<a class="cta-link" href="/projects">View Projects</a>
					<a class="cta-link secondary" href="/contact">Contact</a>
				</div>
			</div>

			<div class="hero-stack">
				<aside class="hero-terminal section-card" data-reveal style="--reveal-order: 1;">
					<p class="section-tag">[MISSION] boot.sequence</p>
					<div class="hero-terminal__screen" data-system-typing>
						{
							typingLines.map((line) => (
								<p class="typing-line is-complete" data-typing-line>{line}</p>
							))
						}
					</div>
				</aside>

				<aside class="hero-panel section-card" data-reveal style="--reveal-order: 2;">
					<p class="section-tag">[MISSION] hero-support</p>
					<p class="section-anchor">section/home/hero-support</p>
					<div class="hud-divider" aria-hidden="true"></div>
					<p>
						Support panel keeps room for future stats, route cues, or short system notes
						without importing the profile-specific status widgets.
					</p>
				</aside>
			</div>
		</section>

		<section class="quote-shell section-card" data-quote-frame data-reveal id="home-quote" style="--reveal-order: 1;">
			<p class="section-kicker">[SYSTEM] quote.protocol</p>
			<p class="section-anchor">section/home/quote-protocol</p>
			<div class="quote-surface">
				<div class="quote-shimmer" aria-hidden="true"></div>
				<p class="sr-only">
					Yesterday is history, tomorrow is a mystery, but today is a gift. That is why it is called the present.
				</p>
				<div aria-hidden="true" class="quote-lines">
					{
						quoteRows.map((row) => (
							<p class="quote-line">
								{
									row.map(({ character, index }) => (
										<span
											class:list={{
												"quote-char": true,
												"is-space": character === " ",
											}}
											style={`--char-index: ${index};`}
										>
											{character === " " ? "\u00A0" : character}
										</span>
									))
								}
							</p>
						))
					}
				</div>
				<div class="quote-underline" aria-hidden="true"></div>
			</div>
		</section>

		<section class="section-card section-shell" data-reveal id="home-intro" style="--reveal-order: 2;">
			<p class="section-kicker">[SYSTEM] home.intro</p>
			<p class="section-anchor">section/home/intro</p>
			<h2>Intro section placeholder now sits inside the same mission HUD language as the rest of the site.</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>
				Placeholder copy still defines the homepage overview, but the information
				hierarchy now reads like a unified system surface instead of isolated cards.
			</p>
		</section>

		<section class="section-card section-shell" data-reveal id="home-focus-areas" style="--reveal-order: 3;">
			<p class="section-kicker">[SYSTEM] home.focus-areas</p>
			<p class="section-anchor">section/home/focus-areas</p>
			<h2>Focus areas remain placeholders while the card treatment upgrades to brighter tactical panels.</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<div class="section-grid">
				<article class="section-card" data-reveal style="--reveal-order: 4;">
					<p class="section-tag">[MISSION] focus-card-01</p>
					<h3>Placeholder focus area one</h3>
					<p>Reserved for short summary text and one future directional cue.</p>
				</article>
				<article class="section-card" data-reveal style="--reveal-order: 5;">
					<p class="section-tag">[MISSION] focus-card-02</p>
					<h3>Placeholder focus area two</h3>
					<p>Reserved for short summary text and one future directional cue.</p>
				</article>
			</div>
		</section>

		<section class="section-card section-shell" data-reveal id="home-featured-pointer" style="--reveal-order: 4;">
			<p class="section-kicker">[SYSTEM] home.featured-pointer</p>
			<p class="section-anchor">section/home/featured-pointer</p>
			<h2>Featured pointer section keeps a clean route into Projects without changing the P4 data flow.</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>
				Only the pointer structure exists here. Project taxonomy and detail-page logic
				continue to stay collection-backed and untouched.
			</p>
			<div class="cta-row">
				<a class="cta-link" href="/projects">Open Projects Hub</a>
			</div>
		</section>

		<section class="section-card section-shell" data-reveal id="home-cta" style="--reveal-order: 5;">
			<p class="section-kicker">[SYSTEM] home.cta-band</p>
			<p class="section-anchor">section/home/cta-band</p>
			<h2>Final CTA band exits the homepage with the same active system framing.</h2>
			<div class="hud-divider" aria-hidden="true"></div>
			<p>Placeholder CTA copy stays generic while the visual layer now feels deliberate and fully themed.</p>
			<div class="cta-row">
				<a class="cta-link" href="/about">Read About</a>
				<a class="cta-link secondary" href="/contact">Start Contact Route</a>
			</div>
		</section>
	</div>
</SiteLayout>

<style>
	.hero-shell {
		align-items: start;
		display: grid;
		gap: 1.25rem;
		grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.95fr);
	}

	.hero-copy,
	.hero-stack {
		display: grid;
		gap: 1rem;
	}

	.hero-title {
		font-size: clamp(2.4rem, 6vw, 4.7rem);
		max-width: 11ch;
		text-wrap: balance;
	}

	.summary {
		font-size: 1.08rem;
		max-width: 42rem;
	}

	.hero-terminal,
	.hero-panel {
		min-height: 100%;
	}

	.hero-terminal__screen {
		background:
			linear-gradient(180deg, rgba(91, 231, 255, 0.07), rgba(91, 231, 255, 0.02)),
			rgba(2, 8, 18, 0.7);
		border: 1px solid rgba(91, 231, 255, 0.14);
		border-radius: 1rem;
		display: grid;
		gap: 0.55rem;
		min-height: 11rem;
		padding: 1rem 1rem 1.05rem;
	}

	.typing-line {
		color: var(--text-bright);
		font-family: var(--font-display);
		font-size: 0.98rem;
		letter-spacing: 0.1em;
		line-height: 1.6;
		margin: 0;
		text-transform: uppercase;
	}

	.typing-line.is-active::after {
		animation: caret-blink 0.9s steps(1, end) infinite;
		color: var(--accent);
		content: "_";
		margin-left: 0.18rem;
	}

	.quote-shell {
		overflow: visible;
		transform:
			perspective(1200px) rotateX(var(--quote-rotate-x, 0deg))
			rotateY(var(--quote-rotate-y, 0deg));
		transition: transform var(--motion-base) var(--easing-standard);
	}

	.quote-shell::before {
		background:
			radial-gradient(circle at var(--quote-x, 50%) var(--quote-y, 50%), rgba(91, 231, 255, 0.2), transparent 22%);
		content: "";
		inset: 0;
		position: absolute;
	}

	.quote-surface {
		display: grid;
		gap: 1.2rem;
		overflow: hidden;
		padding-top: 0.6rem;
		position: relative;
	}

	.quote-shimmer {
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0));
		filter: blur(6px);
		inset: 0 auto 0 -28%;
		opacity: 0.24;
		position: absolute;
		transform: skewX(-20deg);
		width: 18%;
		animation: quote-shimmer-pass 8.6s linear infinite;
	}

	.quote-lines {
		display: grid;
		gap: 1rem;
		justify-items: center;
		position: relative;
		z-index: 1;
	}

	.quote-line {
		font-family: "Dancing Script", "Segoe Script", cursive;
		font-size: clamp(2rem, 4vw, 3.35rem);
		font-weight: 700;
		letter-spacing: 0.02em;
		line-height: 1.22;
		margin: 0;
		text-align: center;
	}

	.quote-char {
		background:
			linear-gradient(90deg, #9fddff 0%, #f8feff 48%, #7ccfff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		display: inline-block;
		filter: drop-shadow(0 0 10px rgba(91, 231, 255, 0.16));
		text-shadow:
			0 0 10px rgba(91, 231, 255, 0.28),
			0 0 22px rgba(255, 255, 255, 0.14);
	}

	.quote-underline {
		background: var(--divider-gradient);
		border-radius: 999px;
		box-shadow:
			0 0 16px rgba(91, 231, 255, 0.3),
			0 0 30px rgba(91, 231, 255, 0.12);
		height: 2px;
		margin: 0 auto;
		position: relative;
		width: min(100%, 64rem);
	}

	.quote-underline::after {
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0));
		content: "";
		inset: 0;
		position: absolute;
		transform: translateX(-130%);
		animation: divider-shimmer 6.2s linear infinite;
	}

	:global(html[data-js="ready"]) .quote-char {
		animation: quote-reveal 0.72s var(--easing-standard) both;
		animation-delay: calc(360ms + (var(--char-index) * 22ms));
		opacity: 0;
		transform: translateY(1rem) scale(0.98);
	}

	@keyframes caret-blink {
		0%,
		49% {
			opacity: 1;
		}

		50%,
		100% {
			opacity: 0;
		}
	}

	@keyframes quote-shimmer-pass {
		0% {
			transform: translateX(-15%) skewX(-20deg);
		}

		100% {
			transform: translateX(730%) skewX(-20deg);
		}
	}

	@keyframes quote-reveal {
		0% {
			opacity: 0;
			transform: translateY(1rem) scale(0.98);
		}

		100% {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@media (max-width: 900px) {
		.hero-shell {
			grid-template-columns: 1fr;
		}

		.hero-title {
			max-width: 100%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.quote-shell,
		.quote-shell::before,
		.quote-shimmer,
		.quote-underline::after {
			animation: none;
			transform: none;
			transition: none;
		}

		.quote-char {
			animation: none;
			opacity: 1;
			transform: none;
		}

		.typing-line.is-active::after {
			animation: none;
			content: "";
		}
	}
</style>
