import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="Aoi Tsukikage Engineering"
	description="Portfolio site bootstrap with shared layout and first-pass routing."
	currentPath={Astro.url.pathname}
>
	<section class="shell">
		<div class="hero-copy">
			<p class="eyebrow">Aoi Tsukikage Engineering</p>
			<h1>Portfolio site bootstrap is live.</h1>
			<p class="summary">A minimal Astro foundation for the GitHub Pages user site.</p>
			<p class="status">Under construction.</p>
		</div>
		<div class="hero-panel">
			<p class="panel-label">Home</p>
			<p>
				This shared shell now anchors the first four routes while the detailed
				information architecture remains intentionally deferred.
			</p>
		</div>
	</section>
</SiteLayout>

<style>
	.shell {
		display: grid;
		gap: 2rem;
		grid-template-columns: minmax(0, 1.6fr) minmax(18rem, 0.9fr);
		min-height: calc(100vh - 14rem);
		place-items: center start;
	}

	.hero-copy {
		display: grid;
		gap: 1rem;
		max-width: 42rem;
	}

	.eyebrow,
	.status,
	.panel-label {
		color: var(--accent);
		letter-spacing: 0.08em;
		margin: 0;
		text-transform: uppercase;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 7vw, 4.5rem);
		line-height: 1.05;
		margin: 0;
	}

	p {
		margin: 0;
		max-width: 40rem;
	}

	.hero-panel {
		background: rgba(120, 192, 255, 0.08);
		border: 1px solid rgba(120, 192, 255, 0.2);
		border-radius: 1.5rem;
		display: grid;
		gap: 1rem;
		padding: 1.5rem;
	}

	.summary {
		font-size: 1.1rem;
		line-height: 1.7;
	}

	@media (max-width: 900px) {
		.shell {
			grid-template-columns: 1fr;
			min-height: auto;
		}
	}
</style>
