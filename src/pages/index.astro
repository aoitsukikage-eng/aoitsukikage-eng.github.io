---
import "../styles/tokens.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Aoi Tsukikage Engineering</title>
	</head>
	<body>
		<main class="shell">
			<p class="eyebrow">Aoi Tsukikage Engineering</p>
			<h1>Portfolio site bootstrap is live.</h1>
			<p class="summary">A minimal Astro foundation for the GitHub Pages user site.</p>
			<p class="status">Under construction.</p>
		</main>
	</body>
</html>

<style>
	:global(html) {
		background: radial-gradient(circle at top, rgba(120, 192, 255, 0.14), transparent 36%), var(--bg);
		color: var(--surface);
		font-family: var(--font-body);
		min-height: 100%;
	}

	:global(body) {
		margin: 0;
		min-height: 100vh;
	}

	.shell {
		box-sizing: border-box;
		display: grid;
		gap: 1rem;
		margin: 0 auto;
		max-width: 48rem;
		min-height: 100vh;
		padding: 6rem 1.5rem;
		place-content: center;
	}

	.eyebrow,
	.status {
		color: var(--accent);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 7vw, 4.5rem);
		line-height: 1.05;
		margin: 0;
	}

	p {
		margin: 0;
		max-width: 40rem;
	}

	.summary {
		font-size: 1.1rem;
		line-height: 1.7;
	}
</style>
