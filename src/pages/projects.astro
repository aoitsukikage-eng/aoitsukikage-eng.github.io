---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="Projects | Aoi Tsukikage Engineering"
	description="Projects route placeholder for the first portfolio information architecture pass."
	currentPath={Astro.url.pathname}
>
	<section class="placeholder">
		<p class="eyebrow">Projects</p>
		<h1>Project listings will be mapped here next.</h1>
		<p>
			This placeholder marks the first routing shell for the projects hub while
			detailed sections, taxonomy, and filtering stay out of scope for P1.
		</p>
	</section>
</SiteLayout>

<style>
	.placeholder {
		display: grid;
		gap: 1rem;
		max-width: 44rem;
	}

	.eyebrow {
		color: var(--accent);
		letter-spacing: 0.08em;
		margin: 0;
		text-transform: uppercase;
	}

	h1 {
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 7vw, 4.25rem);
		line-height: 1.05;
		margin: 0;
	}

	p {
		line-height: 1.7;
		margin: 0;
		max-width: 38rem;
	}
</style>
