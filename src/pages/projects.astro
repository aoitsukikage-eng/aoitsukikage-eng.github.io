---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="Projects | Aoi Tsukikage Engineering"
	description="Projects section scaffold with placeholder CTA and filter placement."
	currentPath={Astro.url.pathname}
>
	<div class="page-stack">
		<section class="section-card section-shell" id="projects-hero">
			<p class="section-kicker">[SYSTEM] projects.hero</p>
			<p class="section-anchor">section/projects/hero</p>
			<h1>Projects page placeholder maps the collection view before content schema exists.</h1>
			<p>
				This hero only establishes heading hierarchy and CTA location for the
				first Projects listing page.
			</p>
			<div class="cta-row">
				<a class="cta-link" href="/contact">Request Details</a>
				<a class="cta-link secondary" href="/">Back Home</a>
			</div>
		</section>

		<section class="section-card section-shell" id="projects-filter-bar">
			<p class="section-kicker">[SYSTEM] projects.filter-bar</p>
			<p class="section-anchor">section/projects/filter-bar</p>
			<h2>Filter bar placement is reserved here without implementing filtering logic.</h2>
			<div class="meta-row">
				<span class="meta-chip">Filter UI Placeholder</span>
				<span class="meta-chip">No Logic</span>
				<span class="meta-chip">No Taxonomy</span>
			</div>
		</section>

		<section class="section-card section-shell" id="projects-grid">
			<p class="section-kicker">[SYSTEM] projects.card-grid</p>
			<p class="section-anchor">section/projects/card-grid</p>
			<h2>Project card grid placeholder defines the listing footprint.</h2>
			<div class="section-grid">
				<article class="section-card">
					<p class="section-tag">[MISSION] card-slot-01</p>
					<h3>Project card placeholder one</h3>
					<p>Reserved for future summary, stack tag, and route pointer.</p>
				</article>
				<article class="section-card">
					<p class="section-tag">[MISSION] card-slot-02</p>
					<h3>Project card placeholder two</h3>
					<p>Reserved for future summary, stack tag, and route pointer.</p>
				</article>
			</div>
		</section>

		<section class="section-card section-shell" id="projects-empty-state">
			<p class="section-kicker">[SYSTEM] projects.empty-state</p>
			<p class="section-anchor">section/projects/empty-state</p>
			<h2>Empty state placeholder documents fallback messaging for the listing surface.</h2>
			<p>
				Placeholder message only. No data model, visibility rule, or slug detail
				route is attached in this pass.
			</p>
			<div class="cta-row">
				<a class="cta-link" href="/contact">Open Contact</a>
			</div>
		</section>
	</div>
</SiteLayout>
