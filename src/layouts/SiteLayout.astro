---
import Nav from "../components/Nav.astro";
import { siteConfig } from "../config/site";
import "../styles/tokens.css";

interface Props {
	title: string;
	currentPath?: string;
	description?: string;
}

const {
	title,
	currentPath = "/",
	description = siteConfig.tagline,
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link
			as="font"
			crossorigin="anonymous"
			href="/fonts/orbitron-500.woff2"
			rel="preload"
			type="font/woff2"
		/>
		<link
			as="font"
			crossorigin="anonymous"
			href="/fonts/dancing-script-700.woff2"
			rel="preload"
			type="font/woff2"
		/>
		<link
			as="font"
			crossorigin="anonymous"
			href="/fonts/ibm-plex-sans-400.woff2"
			rel="preload"
			type="font/woff2"
		/>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<div class="brand-block">
					<p class="eyebrow">[SYSTEM] navigation.core</p>
					<div class="brand-copy">
						<p class="brand-title">{siteConfig.name}</p>
						<p class="brand-note">{siteConfig.tagline}</p>
					</div>
				</div>
				<Nav currentPath={currentPath} />
			</header>
			<main class="content">
				<slot />
			</main>
		</div>

		<script is:inline>
			document.documentElement.dataset.js = "ready";

			const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

			const initReveal = () => {
				const revealNodes = Array.from(document.querySelectorAll("[data-reveal]"));

				if (!revealNodes.length || prefersReducedMotion.matches) {
					revealNodes.forEach((node) => node.classList.add("is-visible"));
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;

							entry.target.classList.add("is-visible");
							observer.unobserve(entry.target);
						});
					},
					{
						rootMargin: "0px 0px -10% 0px",
						threshold: 0.18,
					},
				);

				revealNodes.forEach((node) => observer.observe(node));
			};

			const initTyping = () => {
				const target = document.querySelector("[data-system-typing]");
				if (!target) return;

				const staticLines = Array.from(target.querySelectorAll("[data-typing-line]"))
					.map((line) => line.textContent?.trim() ?? "")
					.filter(Boolean);

				if (!staticLines.length || prefersReducedMotion.matches) {
					return;
				}

				target.innerHTML = "";

				let lineIndex = 0;
				let charIndex = 0;
				let activeLine = null;

				const createLine = () => {
					const line = document.createElement("p");
					line.className = "typing-line is-active";
					target.append(line);
					return line;
				};

				activeLine = createLine();

				const step = () => {
					const currentText = staticLines[lineIndex];
					if (!activeLine || !currentText) return;

					if (charIndex < currentText.length) {
						activeLine.textContent += currentText[charIndex];
						charIndex += 1;
						window.setTimeout(step, 46);
						return;
					}

					activeLine.classList.remove("is-active");
					lineIndex += 1;
					charIndex = 0;

					if (lineIndex >= staticLines.length) {
						activeLine.classList.add("is-complete");
						return;
					}

					activeLine = createLine();
					window.setTimeout(step, 230);
				};

				window.setTimeout(step, 260);
			};

			const initQuote = () => {
				const quoteFrame = document.querySelector("[data-quote-frame]");
				if (!quoteFrame || prefersReducedMotion.matches) return;

				const reset = () => {
					quoteFrame.style.setProperty("--quote-x", "50%");
					quoteFrame.style.setProperty("--quote-y", "50%");
					quoteFrame.style.setProperty("--quote-rotate-x", "0deg");
					quoteFrame.style.setProperty("--quote-rotate-y", "0deg");
				};

				reset();

				quoteFrame.addEventListener("pointermove", (event) => {
					const bounds = quoteFrame.getBoundingClientRect();
					const x = event.clientX - bounds.left;
					const y = event.clientY - bounds.top;
					const xPercent = (x / bounds.width) * 100;
					const yPercent = (y / bounds.height) * 100;
					const rotateX = ((yPercent - 50) / -18).toFixed(2);
					const rotateY = ((xPercent - 50) / 16).toFixed(2);

					quoteFrame.style.setProperty("--quote-x", `${xPercent}%`);
					quoteFrame.style.setProperty("--quote-y", `${yPercent}%`);
					quoteFrame.style.setProperty("--quote-rotate-x", `${rotateX}deg`);
					quoteFrame.style.setProperty("--quote-rotate-y", `${rotateY}deg`);
				});

				quoteFrame.addEventListener("pointerleave", reset);
			};

			const init = () => {
				initReveal();
				initTyping();
				initQuote();
			};

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", init, { once: true });
			} else {
				init();
			}
		</script>
	</body>
</html>

<style>
	:global(html) {
		background: var(--bg);
		color: var(--text-bright);
		font-family: var(--font-body);
		min-height: 100%;
	}

	:global(body) {
		background:
			radial-gradient(circle at top, rgba(91, 231, 255, 0.14), transparent 30%),
			radial-gradient(circle at 85% 18%, rgba(124, 207, 255, 0.1), transparent 22%),
			linear-gradient(180deg, rgba(5, 11, 23, 0.98), rgba(5, 11, 23, 1));
		margin: 0;
		min-height: 100vh;
		overflow-x: hidden;
		position: relative;
	}

	:global(body)::before,
	:global(body)::after {
		content: "";
		inset: 0;
		pointer-events: none;
		position: fixed;
		z-index: -1;
	}

	:global(body)::before {
		background-image:
			linear-gradient(rgba(91, 231, 255, 0.04) 1px, transparent 1px),
			linear-gradient(90deg, rgba(91, 231, 255, 0.04) 1px, transparent 1px);
		background-position: center;
		background-size: 3.5rem 3.5rem;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0));
	}

	:global(body)::after {
		background:
			linear-gradient(180deg, rgba(91, 231, 255, 0.06), transparent 16%),
			radial-gradient(circle at 50% -10%, rgba(91, 231, 255, 0.24), transparent 32%);
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(::selection) {
		background: rgba(91, 231, 255, 0.24);
		color: var(--text-bright);
	}

	:global(a),
	:global(button),
	:global(input),
	:global(textarea) {
		font: inherit;
	}

	:global(a) {
		color: inherit;
	}

	:global(button) {
		cursor: pointer;
	}

	:global(:focus-visible) {
		outline: 2px solid rgba(91, 231, 255, 0.88);
		outline-offset: 3px;
	}

	.page-shell {
		display: grid;
		gap: 2rem;
		margin: 0 auto;
		max-width: 78rem;
		min-height: 100vh;
		padding: 1.75rem 1.2rem 4rem;
		position: relative;
	}

	.site-header {
		background: linear-gradient(180deg, rgba(12, 23, 48, 0.92), rgba(8, 18, 38, 0.9));
		border: 1px solid var(--border-soft);
		border-radius: calc(var(--radius-card) + 0.2rem);
		box-shadow: var(--glow-soft), inset 0 0 0 1px rgba(255, 255, 255, 0.03);
		display: grid;
		gap: 1.4rem;
		overflow: hidden;
		padding: 1.25rem 1.25rem 1.15rem;
		position: sticky;
		top: 1rem;
		z-index: 20;
		backdrop-filter: blur(20px);
	}

	.site-header::before,
	.site-header::after,
	:global(.section-card)::before,
	:global(.section-card)::after {
		content: "";
		pointer-events: none;
		position: absolute;
	}

	.site-header::before,
	:global(.section-card)::before {
		background: var(--divider-gradient);
		height: 1px;
		left: 1.25rem;
		opacity: 0.92;
		right: 1.25rem;
		top: 1rem;
		animation: divider-pulse 4.8s ease-in-out infinite;
	}

	.site-header::after,
	:global(.section-card)::after {
		background:
			linear-gradient(var(--accent), var(--accent)) left 1rem top 1rem / 1.25rem 1px no-repeat,
			linear-gradient(var(--accent), var(--accent)) left 1rem top 1rem / 1px 1.25rem no-repeat,
			linear-gradient(var(--accent), var(--accent)) right 1rem top 1rem / 1.25rem 1px no-repeat,
			linear-gradient(var(--accent), var(--accent)) right 1rem top 1rem / 1px 1.25rem no-repeat,
			linear-gradient(var(--accent), var(--accent)) left 1rem bottom 1rem / 1.25rem 1px no-repeat,
			linear-gradient(var(--accent), var(--accent)) left 1rem bottom 1rem / 1px 1.25rem no-repeat,
			linear-gradient(var(--accent), var(--accent)) right 1rem bottom 1rem / 1.25rem 1px no-repeat,
			linear-gradient(var(--accent), var(--accent)) right 1rem bottom 1rem / 1px 1.25rem no-repeat;
		inset: 0;
		opacity: 0.48;
	}

	.brand-block {
		display: grid;
		gap: 0.7rem;
	}

	.brand-copy {
		display: grid;
		gap: 0.35rem;
	}

	.eyebrow,
	.brand-note,
	.brand-title {
		margin: 0;
	}

	.eyebrow {
		align-items: center;
		background: rgba(91, 231, 255, 0.08);
		border: 1px solid rgba(91, 231, 255, 0.22);
		border-radius: var(--radius-pill);
		color: var(--accent);
		display: inline-flex;
		font-family: var(--font-display);
		font-size: 0.76rem;
		letter-spacing: 0.18em;
		padding: 0.42rem 0.8rem;
		text-transform: uppercase;
		width: fit-content;
	}

	.brand-title {
		font-family: var(--font-display);
		font-size: clamp(1.6rem, 2vw, 2rem);
		letter-spacing: 0.08em;
		line-height: 1.05;
		text-transform: uppercase;
	}

	.brand-note {
		color: var(--text-muted);
		font-size: 0.96rem;
		max-width: 44rem;
	}

	.content {
		display: grid;
		gap: 1.5rem;
	}

	:global(.page-stack) {
		display: grid;
		gap: 1.5rem;
	}

	:global(.section-card),
	:global(.detail-panel),
	:global(.project-card) {
		background: var(--panel-gradient);
		border: 1px solid var(--border-soft);
		border-radius: var(--radius-card);
		box-shadow: var(--glow-soft), inset 0 0 0 1px rgba(255, 255, 255, 0.02);
		display: grid;
		gap: 1rem;
		overflow: hidden;
		padding: 1.5rem;
		position: relative;
		backdrop-filter: blur(18px);
		transition:
			transform var(--motion-base) var(--easing-standard),
			border-color var(--motion-base) var(--easing-standard),
			box-shadow var(--motion-base) var(--easing-standard),
			background var(--motion-base) var(--easing-standard);
	}

	:global(.section-card:hover),
	:global(.section-card:focus-within),
	:global(.detail-panel:hover),
	:global(.detail-panel:focus-within),
	:global(.project-card:hover),
	:global(.project-card:focus-within) {
		border-color: var(--border-strong);
		box-shadow: var(--glow-strong), inset 0 0 0 1px rgba(255, 255, 255, 0.04);
		transform: translateY(-2px);
	}

	:global(.section-shell) {
		display: grid;
		gap: 1rem;
	}

	:global(.section-kicker),
	:global(.section-tag),
	:global(.section-anchor),
	:global(.meta-chip) {
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	:global(.section-kicker),
	:global(.section-tag) {
		align-items: center;
		background: rgba(91, 231, 255, 0.08);
		border: 1px solid rgba(91, 231, 255, 0.18);
		border-radius: var(--radius-pill);
		color: var(--accent);
		display: inline-flex;
		font-family: var(--font-display);
		font-size: 0.76rem;
		gap: 0.45rem;
		margin: 0;
		padding: 0.38rem 0.76rem;
		width: fit-content;
	}

	:global(.section-anchor) {
		color: rgba(183, 236, 255, 0.52);
		font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
		font-size: 0.76rem;
		margin: 0;
	}

	:global(.section-card h1),
	:global(.section-card h2),
	:global(.section-card h3),
	:global(.section-shell h1),
	:global(.section-shell h2),
	:global(.section-shell h3) {
		font-family: var(--font-display);
		letter-spacing: 0.04em;
		line-height: 1.08;
		margin: 0;
		text-transform: uppercase;
	}

	:global(.section-card p),
	:global(.section-shell p),
	:global(.section-card li),
	:global(.section-shell li) {
		color: var(--text-dim);
		line-height: 1.74;
		margin: 0;
	}

	:global(.section-grid) {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	:global(.meta-row),
	:global(.cta-row) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	:global(.meta-chip),
	:global(.project-chip) {
		align-items: center;
		background: rgba(91, 231, 255, 0.08);
		border: 1px solid rgba(91, 231, 255, 0.18);
		border-radius: var(--radius-pill);
		color: rgba(244, 251, 255, 0.82);
		display: inline-flex;
		font-size: 0.78rem;
		gap: 0.4rem;
		padding: 0.45rem 0.78rem;
	}

	:global(.cta-link) {
		align-items: center;
		background:
			linear-gradient(180deg, rgba(14, 29, 58, 0.88), rgba(8, 18, 38, 0.96));
		border: 1px solid rgba(91, 231, 255, 0.24);
		border-radius: var(--radius-pill);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
		color: var(--text-bright);
		display: inline-flex;
		font-family: var(--font-display);
		font-size: 0.85rem;
		letter-spacing: 0.08em;
		padding: 0.8rem 1.1rem;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			transform var(--motion-base) var(--easing-standard),
			border-color var(--motion-base) var(--easing-standard),
			box-shadow var(--motion-base) var(--easing-standard),
			color var(--motion-base) var(--easing-standard),
			background var(--motion-base) var(--easing-standard);
	}

	:global(.cta-link:hover),
	:global(.cta-link:focus-visible) {
		background: linear-gradient(180deg, rgba(20, 43, 82, 0.94), rgba(10, 24, 49, 0.98));
		border-color: rgba(91, 231, 255, 0.52);
		box-shadow: 0 0 22px rgba(91, 231, 255, 0.16);
		color: var(--accent);
		outline: none;
		transform: translateY(-1px);
	}

	:global(.cta-link.secondary) {
		background: rgba(91, 231, 255, 0.06);
		color: var(--text-dim);
	}

	:global(.bullet-list) {
		display: grid;
		gap: 0.75rem;
		margin: 0;
		padding-left: 1.2rem;
	}

	:global(.hud-divider) {
		background: var(--divider-gradient);
		border-radius: 999px;
		box-shadow:
			0 0 18px rgba(91, 231, 255, 0.26),
			0 0 34px rgba(91, 231, 255, 0.08);
		height: 2px;
		overflow: hidden;
		position: relative;
		width: min(100%, 22rem);
	}

	:global(.hud-divider::after) {
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0));
		content: "";
		inset: 0;
		position: absolute;
		transform: translateX(-120%);
		animation: divider-shimmer 5.8s linear infinite;
	}

	:global(.prose-shell) {
		display: grid;
		gap: 1rem;
	}

	:global(.prose-shell ul),
	:global(.prose-shell ol) {
		display: grid;
		gap: 0.65rem;
		margin: 0;
		padding-left: 1.3rem;
	}

	:global(.sr-only) {
		border: 0;
		clip: rect(0 0 0 0);
		height: 1px;
		margin: -1px;
		overflow: hidden;
		padding: 0;
		position: absolute;
		white-space: nowrap;
		width: 1px;
	}

	:global(html[data-js="ready"] [data-reveal]) {
		opacity: 0;
		transform: translateY(22px);
		transition:
			opacity var(--motion-slow) var(--easing-standard),
			transform var(--motion-slow) var(--easing-standard);
		transition-delay: calc(var(--reveal-order, 0) * 80ms);
	}

	:global(html[data-js="ready"] [data-reveal].is-visible) {
		opacity: 1;
		transform: translateY(0);
	}

	@keyframes divider-pulse {
		0%,
		100% {
			opacity: 0.38;
			transform: scaleX(0.98);
		}

		50% {
			opacity: 1;
			transform: scaleX(1);
		}
	}

	@keyframes divider-shimmer {
		0% {
			transform: translateX(-120%);
		}

		100% {
			transform: translateX(120%);
		}
	}

	@media (max-width: 900px) {
		.page-shell {
			padding-inline: 0.9rem;
		}

		:global(.section-grid) {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		:global(html) {
			scroll-behavior: auto;
		}

		.site-header::before,
		:global(.section-card::before),
		:global(.hud-divider::after) {
			animation: none;
		}

		:global(.section-card),
		:global(.detail-panel),
		:global(.project-card),
		:global(.cta-link),
		:global(html[data-js="ready"] [data-reveal]) {
			transition: none;
			transform: none;
		}

		:global(html[data-js="ready"] [data-reveal]) {
			opacity: 1;
		}
	}
</style>
