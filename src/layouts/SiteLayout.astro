---
import Nav from "../components/Nav.astro";
import { siteConfig } from "../config/site";
import "../styles/tokens.css";

interface Props {
	title: string;
	currentPath?: string;
	description?: string;
}

const {
	title,
	currentPath = "/",
	description = siteConfig.tagline,
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="page-shell">
			<header class="site-header">
				<div class="brand-block">
					<p class="eyebrow">{siteConfig.name}</p>
					<p class="brand-note">{siteConfig.tagline}</p>
				</div>
				<Nav currentPath={currentPath} />
			</header>
			<main class="content">
				<slot />
			</main>
		</div>
	</body>
</html>

<style>
	:global(html) {
		background:
			radial-gradient(circle at top, rgba(120, 192, 255, 0.14), transparent 36%),
			var(--bg);
		color: var(--surface);
		font-family: var(--font-body);
		min-height: 100%;
	}

	:global(body) {
		margin: 0;
		min-height: 100vh;
	}

	:global(*) {
		box-sizing: border-box;
	}

	.page-shell {
		display: grid;
		gap: 3rem;
		margin: 0 auto;
		max-width: 72rem;
		min-height: 100vh;
		padding: 2rem 1.5rem 4rem;
	}

	.site-header {
		display: grid;
		gap: 1.5rem;
	}

	.brand-block {
		display: grid;
		gap: 0.35rem;
	}

	.eyebrow,
	.brand-note {
		margin: 0;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.brand-note {
		color: rgba(231, 238, 247, 0.78);
		font-size: 0.98rem;
	}

	.content {
		display: grid;
		gap: 1.5rem;
	}

	:global(.page-stack) {
		display: grid;
		gap: 1.5rem;
	}

	:global(.section-card) {
		background: rgba(120, 192, 255, 0.05);
		border: 1px solid rgba(120, 192, 255, 0.16);
		border-radius: 1.5rem;
		display: grid;
		gap: 1rem;
		padding: 1.5rem;
	}

	:global(.section-shell) {
		display: grid;
		gap: 1rem;
	}

	:global(.section-kicker),
	:global(.section-tag),
	:global(.section-anchor),
	:global(.meta-chip) {
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	:global(.section-kicker),
	:global(.section-tag) {
		color: var(--accent);
		margin: 0;
	}

	:global(.section-anchor) {
		color: rgba(231, 238, 247, 0.6);
		font-size: 0.8rem;
		margin: 0;
	}

	:global(.section-card h1),
	:global(.section-card h2),
	:global(.section-card h3),
	:global(.section-shell h1),
	:global(.section-shell h2),
	:global(.section-shell h3) {
		font-family: var(--font-display);
		line-height: 1.05;
		margin: 0;
	}

	:global(.section-card p),
	:global(.section-shell p),
	:global(.section-card li),
	:global(.section-shell li) {
		line-height: 1.7;
		margin: 0;
	}

	:global(.section-grid) {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	:global(.meta-row),
	:global(.cta-row) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	:global(.meta-chip) {
		border: 1px solid rgba(120, 192, 255, 0.18);
		border-radius: 999px;
		color: rgba(231, 238, 247, 0.76);
		font-size: 0.78rem;
		padding: 0.45rem 0.8rem;
	}

	:global(.cta-link) {
		border: 1px solid rgba(120, 192, 255, 0.24);
		border-radius: 999px;
		color: var(--surface);
		display: inline-flex;
		padding: 0.75rem 1rem;
		text-decoration: none;
	}

	:global(.cta-link:hover),
	:global(.cta-link:focus-visible) {
		background: rgba(120, 192, 255, 0.12);
		border-color: rgba(120, 192, 255, 0.45);
		color: var(--accent);
		outline: none;
	}

	:global(.cta-link.secondary) {
		background: rgba(120, 192, 255, 0.08);
	}

	:global(.bullet-list) {
		display: grid;
		gap: 0.75rem;
		margin: 0;
		padding-left: 1.2rem;
	}

	@media (max-width: 640px) {
		.page-shell {
			padding-top: 1.5rem;
		}
	}

	@media (max-width: 900px) {
		:global(.section-grid) {
			grid-template-columns: 1fr;
		}
	}
</style>
