---
const { currentPath = "/" } = Astro.props;

const links = [
	{ href: "/", label: "Home" },
	{ href: "/projects", label: "Projects" },
	{ href: "/about", label: "About" },
	{ href: "/contact", label: "Contact" },
];

const isActive = (href: string) => {
	if (href === "/") {
		return currentPath === "/";
	}

	return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<nav aria-label="Primary" class="nav">
	<p class="nav-label">[MISSION] route.select</p>
	<ul class="nav-list">
		{
			links.map((link) => {
				const active = isActive(link.href);

				return (
					<li>
						<a
							aria-current={active ? "page" : undefined}
							class:list={{ active }}
							href={link.href}
						>
							<span>{link.label}</span>
						</a>
					</li>
				);
			})
		}
	</ul>
</nav>

<style>
	.nav {
		align-items: start;
		display: grid;
		gap: 0.9rem;
	}

	.nav-label {
		color: var(--accent);
		font-family: var(--font-display);
		font-size: 0.74rem;
		letter-spacing: 0.16em;
		margin: 0;
		text-transform: uppercase;
	}

	.nav-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	a {
		align-items: center;
		background: rgba(91, 231, 255, 0.05);
		border: 1px solid rgba(91, 231, 255, 0.16);
		border-radius: var(--radius-pill);
		color: var(--text-dim);
		display: inline-flex;
		font-family: var(--font-display);
		font-size: 0.84rem;
		letter-spacing: 0.08em;
		padding: 0.78rem 1rem;
		position: relative;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			transform var(--motion-base) var(--easing-standard),
			border-color var(--motion-base) var(--easing-standard),
			box-shadow var(--motion-base) var(--easing-standard),
			color var(--motion-base) var(--easing-standard),
			background var(--motion-base) var(--easing-standard);
	}

	a::before,
	a::after {
		content: "[";
		color: rgba(91, 231, 255, 0.7);
		font-size: 0.82rem;
		margin-right: 0.4rem;
	}

	a::after {
		content: "]";
		margin-left: 0.4rem;
		margin-right: 0;
	}

	a:hover,
	a:focus-visible,
	a.active {
		background: rgba(91, 231, 255, 0.12);
		border-color: rgba(91, 231, 255, 0.48);
		box-shadow: 0 0 22px rgba(91, 231, 255, 0.16);
		color: var(--accent);
		outline: none;
		transform: translateY(-1px);
	}

	@media (max-width: 640px) {
		a {
			padding: 0.7rem 0.85rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		a {
			transition: none;
		}
	}
</style>
