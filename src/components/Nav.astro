---
const { currentPath = "/" } = Astro.props;

const links = [
	{ href: "/", label: "Home" },
	{ href: "/projects", label: "Projects" },
	{ href: "/about", label: "About" },
	{ href: "/contact", label: "Contact" },
];

const isActive = (href: string) => {
	if (href === "/") {
		return currentPath === "/";
	}

	return currentPath === href || currentPath.startsWith(`${href}/`);
};
---

<nav aria-label="Primary" class="nav">
	<ul class="nav-list">
		{
			links.map((link) => {
				const active = isActive(link.href);

				return (
					<li>
						<a
							aria-current={active ? "page" : undefined}
							class:list={{ active }}
							href={link.href}
						>
							{link.label}
						</a>
					</li>
				);
			})
		}
	</ul>
</nav>

<style>
	.nav {
		align-items: center;
		display: flex;
		justify-content: space-between;
	}

	.nav-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	a {
		border: 1px solid rgba(120, 192, 255, 0.2);
		border-radius: 999px;
		color: var(--surface);
		display: inline-flex;
		font-size: 0.95rem;
		padding: 0.65rem 1rem;
		text-decoration: none;
		transition: none;
	}

	a:hover,
	a:focus-visible,
	a.active {
		background: rgba(120, 192, 255, 0.12);
		border-color: rgba(120, 192, 255, 0.45);
		color: var(--accent);
		outline: none;
	}

	@media (max-width: 640px) {
		.nav-list {
			gap: 0.5rem;
		}

		a {
			padding: 0.6rem 0.85rem;
		}
	}
</style>
